{
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "ML Model Alerts",
      "folder": "ML Monitoring",
      "interval": "1m",
      "rules": [
        {
          "uid": "alert-high-error-rate",
          "title": "High Prediction Error Rate",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 300, "to": 0 },
              "model": {
                "expr": "sum(rate(model_prediction_errors_total[5m]))",
                "intervalMs": 1000,
                "maxDataPoints": 43200
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "2m",
          "annotations": {
            "summary": "High prediction error rate detected",
            "description": "The prediction error rate has exceeded the threshold. Current rate: {{ $value }} errors/sec. Check model serving logs."
          },
          "labels": {
            "severity": "critical",
            "team": "mlops"
          }
        },
        {
          "uid": "alert-high-latency",
          "title": "High Prediction Latency",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 300, "to": 0 },
              "model": {
                "expr": "histogram_quantile(0.95, sum(rate(model_request_latency_seconds_bucket[5m])) by (le))",
                "intervalMs": 1000,
                "maxDataPoints": 43200
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "3m",
          "annotations": {
            "summary": "Prediction latency is too high",
            "description": "The p95 prediction latency has exceeded 2 seconds. Current p95: {{ $value }}s. Consider scaling or optimizing the model."
          },
          "labels": {
            "severity": "warning",
            "team": "mlops"
          }
        },
        {
          "uid": "alert-model-f1-drop",
          "title": "Model F1 Score Drop",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 600, "to": 0 },
              "model": {
                "expr": "model_best_f1_score",
                "intervalMs": 1000,
                "maxDataPoints": 43200
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "5m",
          "annotations": {
            "summary": "Model F1 score dropped below threshold",
            "description": "The model F1 score is below 0.7. Current F1: {{ $value }}. Consider retraining the model with updated data."
          },
          "labels": {
            "severity": "critical",
            "team": "mlops"
          }
        }
      ]
    }
  ]
}
